      ]
    },
    "workspace": {
      "machine_id": "dev-intern-02",
      "cwd": "<CIRCLE_EDITING_ROOT>/worktrees/catfish-build-wave-1-a",
      "external_repo": "CircleEditing"
    },
    "agentdoc_receipt": {
      "receipt_id": "ad-circle3d-041",
      "checked_at": "2026-03-28T09:10:00Z",
      "age_minutes": 5,
      "result": "ok"
    },
    "safety_assertions": {
      "no_root_dir_spillover": true,
      "ssh_headroom_preserved": true,
      "storage_within_vepfs_cap": true
    },
    "state": "submitted"
  },
  "approvalExample": {
    "approval_id": "ra-circle3d-017",
    "request_id": "rr-circle3d-017",
    "decision": "approved",
    "approved_at": "2026-03-28T09:17:00Z",
    "approved_by": "circle3d-resource-manager",
    "approved_resources": {
      "gpu_count": 2,
      "vepfs_gb": 16,
      "cpu_cores": 8,
      "memory_gb": 48,
      "write_targets": [
        "<CIRCLE_EDITING_ROOT>/worktrees/catfish-build-wave-1-a",
        "/dev_vepfs/rc_wu/codex_subagents/circle3d-build-wave-1-a"
      ]
    },
    "lease_ttl_minutes": 180,
    "constraints": [
      "Do not exceed 70 percent sustained CPU on dev-intern-02.",
      "Release resources immediately when GPU work completes.",
      "Renew AgentDoc receipt if older than 60 minutes or after a denial."
    ],
    "release_requirements": [
      "emit release event",
      "record actual peak GPU and vePFS usage",
      "confirm all writes stayed under approved roots"
    ]
  },
  "denialExample": {
    "denial_id": "rd-circle3d-021",
    "request_id": "rr-circle3d-021",
