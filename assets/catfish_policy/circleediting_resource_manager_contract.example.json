    "denied_at": "2026-03-28T10:02:00Z",
    "denied_by": "circle3d-resource-manager",
    "reasons": [
      "gpu-cap-exceeded",
      "write-target-outside-approved-root"
    ],
    "retry_policy": "retry-after-reducing-gpu-count-and-moving-output-under-approved-worktree",
    "follow_up_actions": [
      "perform a fresh AgentDoc check before resubmission",
      "update write_targets to an approved CircleEditing worktree path",
      "request no more than 1 additional GPU while other leases remain active"
    ]
  },
  "releaseExample": {
    "release_id": "rl-circle3d-017",
    "approval_id": "ra-circle3d-017",
    "released_at": "2026-03-28T11:40:00Z",
    "released_by": "builder-geo-refactor",
    "actual_usage": {
      "peak_gpu_count": 2,
      "peak_vepfs_gb": 13.4,
      "peak_cpu_cores": 7
    },
    "postconditions": [
