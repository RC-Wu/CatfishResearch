{
  "protocolVersion": "aris.v1",
  "workspaceRoot": "F:\\InformationAndCourses\\Code\\pua_research",
  "agentDocRoot": "F:\\InformationAndCourses\\Code\\AgentDoc",
  "runtimeRoot": "F:\\InformationAndCourses\\Code\\pua_research\\apps\\aris-control-center\\runtime",
  "codexBinaryPath": "codex",
  "remoteLauncherScript": "C:\\Users\\Fantastique\\.codex\\skills\\remote-codex-subagents\\scripts\\remote_codex_subagents.py",
  "routing": {
    "mode": "weighted-multi-account",
    "pinProfileId": "current-session",
    "allowMultiAccount": true,
    "difficultyTierMap": {
      "low": "quick",
      "medium": "balanced",
      "high": "deep"
    },
    "taskKindTierMap": {
      "research": "deep",
      "builder": "balanced",
      "monitor": "quick",
      "summary": "quick",
      "review": "balanced"
    }
  },
  "aris": {
    "dashboardLabel": "ARIS Ops Atlas",
    "defaultResearchShardCount": 72,
    "minResearchShardCount": 60,
    "tmux": {
      "sessionPrefix": "aris",
      "defaultCommand": "python -m http.server 8765"
    },
    "relays": [
      {
        "id": "codex-ai02",
        "label": "Codex AI02",
        "provider": "openai-compatible",
        "baseUrl": "https://codex.ai02.cn/v1",
        "apiKeyEnv": "ARIS_CODEX_AI02_API_KEY",
        "enabled": true,
        "browserCapable": false,
        "tags": ["codex", "research"]
      },
      {
        "id": "llm-chat-env",
        "label": "LLM Chat MCP",
        "provider": "mcp-env-bridge",
        "baseUrl": "env://LLM_BASE_URL",
        "apiKeyEnv": "LLM_API_KEY",
        "enabled": true,
        "browserCapable": false,
        "tags": ["compat", "bridge"]
      }
    ]
  },
  "profiles": [
    {
      "id": "current-session",
      "label": "Current Session",
      "authStrategy": "inherit-current",
      "authRoot": "",
      "enabled": true,
      "allowSelection": true,
      "routingWeight": 1.0,
      "credit": {
        "mode": "manual",
        "remaining": 1000,
        "reserveFloor": 50,
        "sourcePath": ""
      },
      "machineIds": ["pc", "dev-intern-02"],
      "modelTiers": {
        "quick": {
          "model": "gpt-5.4-mini",
          "reasoningEffort": "low",
          "search": false,
          "browserMode": "none"
        },
        "balanced": {
          "model": "gpt-5.4",
          "reasoningEffort": "medium",
          "search": true,
          "browserMode": "codex-search"
        },
        "deep": {
          "model": "gpt-5.4",
          "reasoningEffort": "high",
          "search": true,
          "browserMode": "codex-search"
        }
      }
    },
    {
