{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catfish.local/schemas/capability.schema.json",
  "title": "Catfish Capability Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capabilityId",
    "kind",
    "label",
    "version",
    "allowedStages",
    "strengths",
    "weaknesses",
    "resourceProfile",
    "qualityPriors",
    "parallelism"
  ],
  "properties": {
    "capabilityId": {
      "type": "string",
      "pattern": "^[a-z0-9._-]+$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "provider",
        "model",
        "agent-role",
        "agent-group"
      ]
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "allowedStages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "strengths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "weaknesses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "resourceProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "costBand",
        "latencyBand",
        "throughputBand"
      ],
      "properties": {
        "costBand": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "latencyBand": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "throughputBand": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      }
    },
    "qualityPriors": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expectedQuality",
        "expectedReliability",
        "expectedRisk"
      ],
      "properties": {
        "expectedQuality": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "expectedReliability": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "expectedRisk": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "parallelism": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxConcurrentChildren",
        "burstTolerance"
      ],
      "properties": {
        "maxConcurrentChildren": {
          "type": "integer",
          "minimum": 1
        },
        "burstTolerance": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      }
    },
    "failureModes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
